# Copy this file to .env.local and fill in your connection string.
# .env.local is gitignored and must never be committed.
#
# Option 1 — let the tooling provision one for you:
#   make db-provision
#   Spins up an ephemeral Neon database via neon-new and writes
#   ATOMIK_DATABASE_URL here automatically. Unclaimed instances
#   expire; run `make db-provision` again when yours does.
#
# Option 2 — bring your own:
#   Neon branch:  postgres://user:pass@host.neon.tech/dbname?sslmode=require
#   Supabase:     postgres://postgres:pass@host.supabase.co:5432/postgres
#   Local:        postgres://localhost/atomik_dev
#   Docker:       postgres://postgres:postgres@localhost:5432/atomik_test
#
# The schema is applied automatically on first run (CREATE TABLE IF NOT EXISTS).
# You can also apply it manually: psql $ATOMIK_DATABASE_URL < init.sql

ATOMIK_DATABASE_URL=
